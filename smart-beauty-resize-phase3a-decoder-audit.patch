+def _source_bit_depth(image: Image.Image) -> int | None:
+    """Return source sample depth using raw decoder metadata when available."""
+    if image.mode == "1":
+        return 1
+
+    for tile in getattr(image, "tile", ()):
+        raw_mode = getattr(tile, "args", None)
+        if raw_mode is None:
