+def test_audit_only_preserves_rgba_conversion_behavior(
+    tmp_path: Path,
+) -> None:
+    input_dir = tmp_path / "input"
+    output_dir = tmp_path / "output"
+    input_dir.mkdir()
+
+    rgba = np.zeros((8, 12, 4), dtype=np.uint8)
+    rgba[:, :, :3] = 100
+    rgba[:, :, 3] = 128
